# Database
# 로컬: mysql://root:password@localhost:3306/academy
# Railway: mysql://root:password@mysql.railway.internal:3306/railway
DATABASE_URL="mysql://root:password@localhost:3306/academy"

# JWT (프로덕션에서는 반드시 32자 이상의 랜덤 문자열로 변경)
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-minimum-32-characters-long"

# Server
PORT=4000
NODE_ENV=development

# CORS
# 로컬: http://localhost:5173
# 프로덕션: https://your-app.vercel.app
CORS_ORIGIN="http://localhost:5173"

# Kakao 알림톡 (보강 알림 등)
KAKAO_API_KEY=""
KAKAO_SENDER_KEY=""
