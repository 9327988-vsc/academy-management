generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 사용자 (기본)
// ============================================
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      Role
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  teacherProfile Teacher?
  studentProfile Student?
  parentProfile  Parent?

  notificationPreferences NotificationPreference[]

  @@index([email])
  @@index([role])
}

enum Role {
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

// ============================================
// 강사
// ============================================
model Teacher {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone          String
  email          String
  education      String?  @db.Text
  career         String?  @db.Text
  subjects       Json?
  introduction   String?  @db.Text
  photoUrl       String?
  hireDate       DateTime @default(now())
  employmentType String   @default("정규직")
  hourlyRate     Int?
  salary         Int?
  totalStudents  Int      @default(0)
  totalClasses   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  classes          Class[]
  consultations    Consultation[]
  teacherSchedules TeacherSchedule[]
  salaryRecords    SalaryRecord[]
  makeupSlots      MakeupSlot[]

  @@index([userId])
}

// ============================================
// 학생
// ============================================
model Student {
  id               Int           @id @default(autoincrement())
  userId           Int?          @unique
  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  phone            String
  grade            String?
  school           String?
  birthDate        DateTime?
  address          String?       @db.Text
  parentId         Int?
  parent           Parent?       @relation(fields: [parentId], references: [id], onDelete: SetNull)
  registrationDate DateTime      @default(now())
  status           StudentStatus @default(ACTIVE)
  totalEnrollments Int           @default(0)
  attendanceRate   Float         @default(100)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  enrollments    Enrollment[]
  attendances    Attendance[]
  payments       Payment[]
  consultations  Consultation[]
  homeworks      Homework[]
  grades         Grade[]
  makeupRequests MakeupRequest[]

  @@index([parentId])
  @@index([phone])
  @@index([status])
}

enum StudentStatus {
  ACTIVE
  WITHDRAWN
  SUSPENDED
  GRADUATED
}

// ============================================
// 학부모
// ============================================
model Parent {
  id        Int      @id @default(autoincrement())
  userId    Int?     @unique
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  phone     String   @unique
  email     String?
  relation  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students Student[]

  @@index([phone])
}

// ============================================
// 수업
// ============================================
model Class {
  id              Int         @id @default(autoincrement())
  name            String
  subject         String
  description     String?     @db.Text
  teacherId       Int
  teacher         Teacher     @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  schedule        String
  startDate       DateTime
  endDate         DateTime
  room            String?
  capacity        Int         @default(15)
  tuitionFee      Int
  status          ClassStatus @default(ACTIVE)
  currentStudents Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  enrollments   Enrollment[]
  attendances   Attendance[]
  schedules     ClassSchedule[]
  homeworks     ClassHomework[]
  makeupSlots   MakeupSlot[]

  @@index([teacherId])
  @@index([status])
}

enum ClassStatus {
  ACTIVE
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ============================================
// 수강 신청
// ============================================
model Enrollment {
  id             Int              @id @default(autoincrement())
  studentId      Int
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId        Int
  class          Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollmentDate DateTime         @default(now())
  status         EnrollmentStatus @default(ACTIVE)
  tuitionFee     Int
  discount       Int              @default(0)
  finalFee       Int
  note           String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([studentId, classId])
  @@index([studentId])
  @@index([classId])
  @@index([status])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
  SUSPENDED
}

// ============================================
// 출석
// ============================================
model Attendance {
  id           Int              @id @default(autoincrement())
  studentId    Int
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId      Int
  class        Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  date         DateTime
  status       AttendanceStatus
  checkInTime  DateTime?
  checkOutTime DateTime?
  note         String?          @db.Text
  recordedBy   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  makeupRequests MakeupRequest[]

  @@unique([studentId, classId, date])
  @@index([studentId])
  @@index([classId])
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ============================================
// 결제
// ============================================
model Payment {
  id          Int           @id @default(autoincrement())
  studentId   Int
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount      Int
  dueDate     DateTime
  paidDate    DateTime?
  status      PaymentStatus @default(PENDING)
  month       String
  description String?       @db.Text
  method      String?
  receiptUrl  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([dueDate])
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ============================================
// 상담/면담
// ============================================
model Consultation {
  id            Int                @id @default(autoincrement())
  studentId     Int
  student       Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherId     Int
  teacher       Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  scheduledDate DateTime
  actualDate    DateTime?
  duration      Int?
  type          ConsultationType
  status        ConsultationStatus @default(SCHEDULED)
  topic         String?            @db.Text
  content       String?            @db.Text
  outcome       String?            @db.Text
  attendees     String?            @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([studentId])
  @@index([teacherId])
  @@index([scheduledDate])
}

enum ConsultationType {
  INITIAL
  REGULAR
  EMERGENCY
  PARENT
}

enum ConsultationStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// 숙제
// ============================================
model ClassHomework {
  id          Int      @id @default(autoincrement())
  classId     Int
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  description String   @db.Text
  dueDate     DateTime
  fileUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Homework[]

  @@index([classId])
  @@index([dueDate])
}

model Homework {
  id              Int            @id @default(autoincrement())
  classHomeworkId Int
  classHomework   ClassHomework  @relation(fields: [classHomeworkId], references: [id], onDelete: Cascade)
  studentId       Int
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status          HomeworkStatus @default(PENDING)
  submittedDate   DateTime?
  content         String?        @db.Text
  fileUrl         String?
  grade           String?
  feedback        String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([classHomeworkId, studentId])
  @@index([studentId])
  @@index([status])
}

enum HomeworkStatus {
  PENDING
  SUBMITTED
  LATE
  GRADED
}

// ============================================
// 성적
// ============================================
model Grade {
  id         Int      @id @default(autoincrement())
  studentId  Int
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examName   String
  examDate   DateTime
  subject    String
  score      Float
  maxScore   Float
  percentage Float
  rank       Int?
  grade      String?
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([studentId])
  @@index([examDate])
}

// ============================================
// 강사 일정
// ============================================
model TeacherSchedule {
  id          Int          @id @default(autoincrement())
  teacherId   Int
  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String
  endTime     String
  type        ScheduleType
  title       String
  description String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([teacherId])
  @@index([date])
}

enum ScheduleType {
  CLASS
  MEETING
  CONSULTATION
  BREAK
  OTHER
}

// ============================================
// 수업 일정
// ============================================
model ClassSchedule {
  id           Int                 @id @default(autoincrement())
  classId      Int
  class        Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  date         DateTime
  startTime    String
  endTime      String
  status       ClassScheduleStatus @default(SCHEDULED)
  originalDate DateTime?
  reason       String?             @db.Text
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([classId])
  @@index([date])
}

enum ClassScheduleStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

// ============================================
// 급여
// ============================================
model SalaryRecord {
  id          Int          @id @default(autoincrement())
  teacherId   Int
  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  month       String
  workHours   Float
  hourlyRate  Int?
  baseSalary  Int
  bonus       Int          @default(0)
  deduction   Int          @default(0)
  totalSalary Int
  paymentDate DateTime?
  status      SalaryStatus @default(PENDING)
  detail      String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([teacherId, month])
  @@index([teacherId])
  @@index([month])
}

enum SalaryStatus {
  PENDING
  PAID
  CANCELLED
}

enum MakeupSlotStatus {
  AVAILABLE
  FULL
  CLOSED
}

enum MakeupRequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum NotificationChannel {
  SMS
  KAKAO
  PUSH
  EMAIL
}

enum NotificationTemplateType {
  SESSION_SUMMARY
  ABSENT_NOTICE
  MAKEUP_REMINDER
  MAKEUP_CONFIRMED
  MAKEUP_REJECTED
  WEEKLY_REPORT
  GENERAL
}

// ============================================
// 학원 설정
// ============================================
model AcademySettings {
  id             Int      @id @default(autoincrement())
  academyName    String?
  ownerName      String?
  phone          String?
  address        String?
  businessNumber String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================
// 보강 가능 시간
// ============================================
model MakeupSlot {
  id           Int              @id @default(autoincrement())
  teacherId    Int
  teacher      Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classId      Int?
  class        Class?           @relation(fields: [classId], references: [id], onDelete: SetNull)
  slotDate     DateTime         @db.Date
  startTime    String
  endTime      String
  maxStudents  Int              @default(3)
  currentCount Int              @default(0)
  status       MakeupSlotStatus @default(AVAILABLE)
  isRecurring  Boolean          @default(false)
  recurringDay String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  requests MakeupRequest[]

  @@index([teacherId])
  @@index([classId])
  @@index([slotDate])
  @@index([status])
  @@index([teacherId, slotDate, status])
}

// ============================================
// 보강 신청
// ============================================
model MakeupRequest {
  id                   Int                 @id @default(autoincrement())
  studentId            Int
  student              Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  originalAttendanceId Int
  originalAttendance   Attendance          @relation(fields: [originalAttendanceId], references: [id], onDelete: Restrict)
  slotId               Int
  slot                 MakeupSlot          @relation(fields: [slotId], references: [id], onDelete: Cascade)
  status               MakeupRequestStatus @default(PENDING)
  studentNote          String?             @db.Text
  teacherNote          String?             @db.Text
  requestedAt          DateTime            @default(now())
  approvedAt           DateTime?
  completedAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@unique([studentId, originalAttendanceId])
  @@index([studentId])
  @@index([slotId])
  @@index([status])
  @@index([originalAttendanceId])
}

// ============================================
// 알림 템플릿
// ============================================
model NotificationTemplate {
  id           Int                      @id @default(autoincrement())
  type         NotificationTemplateType
  channel      NotificationChannel
  name         String
  templateCode String?
  content      String                   @db.Text
  variables    Json?
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([type, channel])
  @@index([isActive])
}

// ============================================
// 알림 수신 설정
// ============================================
model NotificationPreference {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationType String
  channelSms       Boolean  @default(true)
  channelKakao     Boolean  @default(true)
  channelPush      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, notificationType])
  @@index([userId])
}
